# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# API Keys (AI providers)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Default model
DEFAULT_MODEL=claude-sonnet-4-6
PLANNING_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-haiku-4-5-20251001
EXECUTION_MODEL=claude-sonnet-4-6
VALIDATION_MODEL=claude-haiku-4-5-20251001

# vLLM (when running local inference)
VLLM_HOST=localhost
VLLM_PORT=8080
VLLM_MODEL=meta-llama/Llama-2-70b-chat-hf
VLLM_TENSOR_PARALLEL_SIZE=4
VLLM_GPU_MEMORY_UTILIZATION=0.90

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_inference_stack
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_POOL_SIZE=20

# Orchestrator
MAX_CONCURRENT_AGENTS=10
REQUEST_TIMEOUT_SECONDS=300
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1

# Search integrations
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
BING_SEARCH_API_KEY=your_bing_search_api_key_here

# CRM integrations
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
HUBSPOT_API_KEY=

# Monitoring
PROMETHEUS_PORT=9090
JAEGER_HOST=localhost
JAEGER_PORT=6831
OTLP_ENDPOINT=http://localhost:4317

# Cost tracking
COST_PER_1K_INPUT_TOKENS=0.003
COST_PER_1K_OUTPUT_TOKENS=0.015

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
